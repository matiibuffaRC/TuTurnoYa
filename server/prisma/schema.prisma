datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nombre    String
  email     String   @unique
  password  String
  rol       String   @default("CLIENTE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación 1:1 inversa con Barbero (opcional en el modelo Usuario, ya que no todos los usuarios son barberos)
  barbero   Barbero?
}

model Cliente {
  id       Int     @id @default(autoincrement())
  nombre   String
  apellido String
  email    String  @unique
  turnos   Turno[]
}

model Sucursal {
  id              Int       @id @default(autoincrement())
  nombre          String
  direccion       String
  telefono        String
  horarioApertura String
  horarioCierre   String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relación 1:N con Barberos
  barberos        Barbero[]
}

model Barbero {
  id             Int      @id @default(autoincrement())
  nombre         String
  apellido       String
  telefono       String
  email          String   @unique
  activo         Boolean  @default(true)
  agendaAbierta  Boolean  @default(true)
  horarioEntrada String   @default("09:00")
  horarioSalida  String   @default("18:00")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relación 1:N con Sucursal
  sucursalId     Int
  sucursal       Sucursal @relation(fields: [sucursalId], references: [id], onDelete: Cascade)

  // Relación 1:1 con Usuario (Cada barbero operativo TIENE que tener una cuenta de acceso)
  usuarioId      Int      @unique
  usuario        Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  // Relación con Turnos
  turnos         Turno[]
}

model Servicio {
  id       Int     @id @default(autoincrement())
  tipo     String
  precio   Float
  duracion Int
  turnos   Turno[]
}

model Turno {
  id         Int      @id @default(autoincrement())
  fecha      String
  hora       String
  estado     String   @default("activo")
  clienteId  Int
  cliente    Cliente  @relation(fields: [clienteId], references: [id])
  barberoId  Int
  barbero    Barbero  @relation(fields: [barberoId], references: [id])
  servicioId Int
  servicio   Servicio @relation(fields: [servicioId], references: [id])
  creadoEn   DateTime @default(now())
}